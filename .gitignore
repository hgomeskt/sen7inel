# ============================================================
# Sen7inel — .gitignore
# ============================================================

# Secrets — NEVER in Git
.env
.env.*
!.env.example

# Ephemeral sandbox results
/tmp/
**/sen7inel-results/

# Node
node_modules/
dist/
build/
*.js.map

# TypeScript build
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Client repositories (mounted at runtime)
/opt/sen7inel/repos/

# Temporary patches
*.diff
*.patch