{
  "name": "Sen7inel — Self-Healing Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sen7inel/fix",
        "authentication": "headerAuth",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "node-webhook",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "position": [
        200,
        300
      ]
    },
    {
      "parameters": {
        "command": "cat /opt/sen7inel/client-profiles/{{ $json.client_id }}/FORBIDDEN.md && echo '---STACK---' && cat /opt/sen7inel/client-profiles/{{ $json.client_id }}/STACK.md && echo '---SKILLS---' && cat /opt/sen7inel/.agent/skills/security/flat-architecture.md && cat /opt/sen7inel/.agent/skills/meta/complexity-budget.md"
      },
      "id": "node-load-context",
      "name": "Load Client Context",
      "type": "n8n-nodes-base.executeCommand",
      "position": [
        400,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = items[0].json;\nconst crypto = require('crypto');\nreturn [{\n  json: {\n    ...item,\n    client_context: item.stdout,\n    iteration: 1,\n    max_iterations: 3,\n    patch_hash: crypto.createHash('sha256')\n      .update(item.anomaly_description + Date.now())\n      .digest('hex').slice(0, 16),\n    reviewer_system_prompt: require('fs').readFileSync('/opt/sen7inel/prompts/reviewer-gemini-system-prompt.md', 'utf8'),\n  }\n}];"
      },
      "id": "node-init",
      "name": "Initialize Pipeline",
      "type": "n8n-nodes-base.code",
      "position": [
        600,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = items[0].json;\nconst fs = require('fs');\n\nconst systemPrompt = item.client_context + '\\n\\n---\\n\\n' +\n  fs.readFileSync('/opt/sen7inel/prompts/generator-claude-system-prompt.md', 'utf8');\n\nlet userMessage = `[ANOMALY]\\nType: ${item.anomaly_type}\\nDescription: ${item.anomaly_description}\\nStack Trace:\\n${item.stack_trace ?? 'Not provided'}\\n\\n[AFFECTED_CODE]\\n${(item.affected_files ?? []).join('\\n')}`;\n\nif (item.refinementContext) {\n  userMessage = `[PREVIOUS_ATTEMPT_FAILED]\\nIteration: ${item.iteration - 1}\\n${item.refinementContext.instruction}\\n\\nError Output:\\n${item.refinementContext.errorOutput}\\n\\n[ORIGINAL_ANOMALY]\\n${userMessage}`;\n}\n\nif (item.flattenRequest) {\n  const violations = item.flattenRequest.violations\n    .map(v => `- ${v.name} in ${v.filePath}:${v.line} (CC=${v.cyclomaticComplexity})`)\n    .join('\\n');\n  userMessage = `[REFACTOR_REQUIRED — FLATTEN COMPLEXITY ONLY]\\n${item.flattenRequest.instruction}\\n\\nViolations:\\n${violations}\\n\\n[CONTEXT]\\n${userMessage}`;\n}\n\nreturn [{ json: { ...item, generator_system_prompt: systemPrompt, generator_user_message: userMessage } }];"
      },
      "id": "node-build-prompt",
      "name": "Build Generator Prompt",
      "type": "n8n-nodes-base.code",
      "position": [
        800,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={\"model\":\"claude-sonnet-4-20250514\",\"max_tokens\":4096,\"temperature\":0.1,\"system\":\"{{ $json.generator_system_prompt }}\",\"messages\":[{\"role\":\"user\",\"content\":\"{{ $json.generator_user_message }}\"}]}"
            }
          ]
        },
        "options": {
          "timeout": 60000
        }
      },
      "id": "node-claude",
      "name": "Claude 3.5 — Generate Patch",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1000,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = items[0].json;\nconst content = response.content?.[0]?.text ?? '';\nconst isDecompose = content.trim().startsWith('DECOMPOSE');\nreturn [{ json: { ...items[0].json, patch_content: isDecompose ? '' : content, decompose_requested: isDecompose } }];"
      },
      "id": "node-extract-patch",
      "name": "Extract Patch",
      "type": "n8n-nodes-base.code",
      "position": [
        1200,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={\"system_instruction\":{\"parts\":[{\"text\":\"{{ $json.reviewer_system_prompt }}\"}]},\"contents\":[{\"role\":\"user\",\"parts\":[{\"text\":\"[DIFF]\\n{{ $json.patch_content }}\\n\\n[CONSTRAINTS]\\n{{ $json.client_context }}\"}]}],\"generationConfig\":{\"temperature\":0.0,\"maxOutputTokens\":256}}"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "node-gemini",
      "name": "Gemini — Adversarial Review",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1400,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const responseText = items[0].json.candidates?.[0]?.content?.parts?.[0]?.text ?? '';\nconst isApproved = responseText.trim().startsWith('APPROVE');\nconst codeMatch = responseText.match(/CODE:\\s*(.+)/);\nconst reasonMatch = responseText.match(/REASON:\\s*(.+)/);\nreturn [{ json: { ...items[0].json, reviewer_approved: isApproved, reviewer_response: responseText, reviewer_reject_code: codeMatch?.[1]?.trim(), reviewer_reject_reason: reasonMatch?.[1]?.trim() } }];"
      },
      "id": "node-parse-review",
      "name": "Parse Review Response",
      "type": "n8n-nodes-base.code",
      "position": [
        1600,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.reviewer_approved }}",
              "value2": true
            }
          ]
        }
      },
      "id": "node-if-approved",
      "name": "IF: Reviewer Approved?",
      "type": "n8n-nodes-base.if",
      "position": [
        1800,
        300
      ]
    },
    {
      "parameters": {
        "command": "node /opt/sen7inel/sandbox/scripts/execute-fix.js --client-id={{ $json.client_id }} --patch-hash={{ $json.patch_hash }} --repo-path={{ $json.repo_path }} --iteration={{ $json.iteration }} --patch-content={{ $json.patch_content }}",
        "options": {
          "continueOnFail": true
        }
      },
      "id": "node-execute-fix",
      "name": "Execute Fix — Sandbox",
      "type": "n8n-nodes-base.executeCommand",
      "position": [
        2000,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const stdout = items[0].json.stdout ?? '{}';\nlet verifyResult;\ntry { verifyResult = JSON.parse(stdout); } catch { verifyResult = { status: 'SYSTEM_ERROR', isGreen: false, requiresHumanEscalation: true, needsComplexityFlatten: false, needsRefinement: false }; }\nreturn [{ json: { ...items[0].json, ...verifyResult } }];"
      },
      "id": "node-parse-verify",
      "name": "Parse Verify Result",
      "type": "n8n-nodes-base.code",
      "position": [
        2200,
        200
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.isGreen }}",
              "value2": true
            }
          ]
        }
      },
      "id": "node-if-green",
      "name": "IF: isGreen?",
      "type": "n8n-nodes-base.if",
      "position": [
        2400,
        200
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.needsComplexityFlatten }}",
              "value2": true
            }
          ]
        }
      },
      "id": "node-if-complexity",
      "name": "IF: Complexity Violation?",
      "type": "n8n-nodes-base.if",
      "position": [
        2600,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.iteration }}",
              "operation": "smallerThan",
              "value2": "={{ $json.max_iterations }}"
            }
          ]
        }
      },
      "id": "node-if-retry",
      "name": "IF: Can Retry?",
      "type": "n8n-nodes-base.if",
      "position": [
        2800,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...items[0].json, iteration: items[0].json.iteration + 1 } }];"
      },
      "id": "node-increment",
      "name": "Increment Iteration",
      "type": "n8n-nodes-base.code",
      "position": [
        3000,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/{{ $json.github_owner }}/{{ $json.github_repo }}/pulls",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={\"title\":\"[Sen7inel] Fix: {{ $json.anomaly_type }}\",\"body\":\"## Sen7inel Auto-Fix\\n\\n**Client**: {{ $json.client_id }}\\n**Patch Hash**: `{{ $json.patch_hash }}`\\n**Iterations**: {{ $json.iteration }}\\n**CC Max**: {{ $json.complexity.maxFound }}/10\",\"head\":\"sen7inel/fix-{{ $json.patch_hash }}\",\"base\":\"main\",\"draft\":false}"
            }
          ]
        }
      },
      "id": "node-create-pr",
      "name": "Create Pull Request",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2600,
        100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SLACK_WEBHOOK_URL }}",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={\"text\":\"🔴 *Sen7inel — Escalação Humana*\\n\\n*Cliente:* {{ $json.client_id }}\\n*Status:* `{{ $json.status }}`\\n*Iterações:* {{ $json.iteration }}/{{ $json.max_iterations }}\\n*Patch Hash:* `{{ $json.patch_hash }}`\\n*Motivo:* {{ $json.error ?? $json.refinementContext.errorOutput }}\"}"
            }
          ]
        }
      },
      "id": "node-escalate",
      "name": "Human Escalation Alert",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        3000,
        400
      ]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          {
            "node": "Load Client Context",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Load Client Context": {
      "main": [
        [
          {
            "node": "Initialize Pipeline",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Initialize Pipeline": {
      "main": [
        [
          {
            "node": "Build Generator Prompt",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Generator Prompt": {
      "main": [
        [
          {
            "node": "Claude 3.5 — Generate Patch",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Claude 3.5 — Generate Patch": {
      "main": [
        [
          {
            "node": "Extract Patch",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Patch": {
      "main": [
        [
          {
            "node": "Gemini — Adversarial Review",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gemini — Adversarial Review": {
      "main": [
        [
          {
            "node": "Parse Review Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Review Response": {
      "main": [
        [
          {
            "node": "IF: Reviewer Approved?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF: Reviewer Approved?": {
      "main": [
        [
          {
            "node": "Execute Fix — Sandbox",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "IF: Can Retry?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Execute Fix — Sandbox": {
      "main": [
        [
          {
            "node": "Parse Verify Result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Verify Result": {
      "main": [
        [
          {
            "node": "IF: isGreen?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF: isGreen?": {
      "main": [
        [
          {
            "node": "Create Pull Request",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "IF: Complexity Violation?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF: Complexity Violation?": {
      "main": [
        [
          {
            "node": "IF: Can Retry?",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "IF: Can Retry?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF: Can Retry?": {
      "main": [
        [
          {
            "node": "Increment Iteration",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Human Escalation Alert",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Increment Iteration": {
      "main": [
        [
          {
            "node": "Build Generator Prompt",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": "sen7inel-error-handler"
  },
  "tags": [
    "sen7inel",
    "self-healing",
    "production"
  ]
}